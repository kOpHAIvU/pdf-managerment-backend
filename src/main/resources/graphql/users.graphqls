type User {
  id: String
  email: String
  fullName: String
  provider: String
  createdAt: String
}

type AuthPayload {
  token: String
  user: User
}

type Query {
  me: User
}

type Mutation {
  login(email: String!, password: String!): AuthPayload

  register(fullName: String!, email: String!, password: String!): AuthPayload

  loginWithGoogle(idToken: String!): AuthPayload
}
